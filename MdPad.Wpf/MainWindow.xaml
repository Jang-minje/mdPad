<Window x:Class="MdPad.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="MD Pad" Width="1180" Height="780" MinWidth="760" MinHeight="520"
        Icon="/Assets/App.ico"
        Background="#F5F2EA"
        AllowDrop="True"
        DragOver="Window_OnDragOver"
        Drop="Window_OnDrop"
        Closing="Window_OnClosing">
    <Window.Resources>
        <SolidColorBrush x:Key="ChromeBrush" Color="#1E1E1E" />
        <SolidColorBrush x:Key="ChromeElevatedBrush" Color="#2B2B2B" />
        <SolidColorBrush x:Key="AccentBrush" Color="#D7A21C" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FAFAFA" />
        <SolidColorBrush x:Key="SurfaceMutedBrush" Color="#E6E1D8" />
        <SolidColorBrush x:Key="LineBrush" Color="#B8B8B8" />
        <SolidColorBrush x:Key="TextBrush" Color="#111827" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#5F6368" />

        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="26" />
            <Setter Property="MinWidth" Value="54" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="Background" Value="#2B2B2B" />
            <Setter Property="BorderBrush" Value="#4A4A4A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#E6E6E6" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#3A3A3A" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#6A6A6A" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#202020" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="Background" Value="#F2C94C" />
            <Setter Property="BorderBrush" Value="#D6A719" />
            <Setter Property="Foreground" Value="#1F1F1F" />
        </Style>

        <Style x:Key="LightButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="Background" Value="#FFFDF8" />
            <Setter Property="BorderBrush" Value="#D8C9A9" />
            <Setter Property="Foreground" Value="#172033" />
        </Style>

        <Style x:Key="SearchButtonStyle" TargetType="Button" BasedOn="{StaticResource LightButtonStyle}">
            <Setter Property="Height" Value="30" />
            <Setter Property="MinWidth" Value="54" />
            <Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="Padding" Value="10,0" />
        </Style>

        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#FFFDF8" />
            <Setter Property="BorderBrush" Value="#D8C9A9" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#172033" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#F6ECD4" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#EBDDBF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModeButtonStyle" TargetType="RadioButton">
            <Setter Property="Height" Value="26" />
            <Setter Property="MinWidth" Value="74" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="Foreground" Value="#CBD5E1" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root" Background="Transparent" BorderBrush="#4A4A4A" BorderThickness="1" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#3A3A3A" />
                                <Setter Property="Foreground" Value="#F8FAFC" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#4D5D5D" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#6F8585" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="#FFFDF8" />
            <Setter Property="BorderBrush" Value="#D8C9A9" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#172033" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#D6A719" />
                                <Setter TargetName="Root" Property="BorderThickness" Value="2" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PeerComboStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="26" />
            <Setter Property="Width" Value="190" />
            <Setter Property="Margin" Value="8,0,4,0" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Background" Value="#F5F5F5" />
            <Setter Property="Foreground" Value="#111827" />
            <Setter Property="BorderBrush" Value="#777777" />
        </Style>

        <Style x:Key="TabListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TopMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Foreground" Value="#E6E6E6" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="DropDownMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Foreground" Value="#111111" />
            <Setter Property="Background" Value="#F0F0F0" />
            <Setter Property="FontSize" Value="12" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="32" />
            <RowDefinition Height="*" />
            <RowDefinition Height="30" />
        </Grid.RowDefinitions>

        <Menu x:Name="MainMenu" Grid.Row="0" Background="#1E1E1E" Foreground="#E6E6E6" FontSize="12" Padding="2,0" ItemContainerStyle="{StaticResource TopMenuItemStyle}">
            <MenuItem Header="파일(_F)" ItemContainerStyle="{StaticResource DropDownMenuItemStyle}">
                <MenuItem Header="새 탭" InputGestureText="Ctrl+N" Click="NewButton_OnClick" />
                <MenuItem Header="열기..." InputGestureText="Ctrl+O" Click="OpenButton_OnClick" />
                <Separator />
                <MenuItem Header="저장" InputGestureText="Ctrl+S" Click="SaveButton_OnClick" />
                <MenuItem Header="다른 이름으로 저장..." Click="SaveAsButton_OnClick" />
                <Separator />
                <MenuItem Header="탭 닫기" Click="CloseTabButton_OnClick" />
            </MenuItem>
            <MenuItem Header="편집(_E)" ItemContainerStyle="{StaticResource DropDownMenuItemStyle}">
                <MenuItem Header="찾기" InputGestureText="Ctrl+F" Click="ShowSearchMenuItem_OnClick" />
                <MenuItem Header="글자 크게" InputGestureText="Ctrl+Wheel Up" Click="IncreaseFontMenuItem_OnClick" />
                <MenuItem Header="글자 작게" InputGestureText="Ctrl+Wheel Down" Click="DecreaseFontMenuItem_OnClick" />
            </MenuItem>
            <MenuItem Header="보기(_V)" ItemContainerStyle="{StaticResource DropDownMenuItemStyle}">
                <MenuItem Header="편집 모드" Click="EditModeMenuItem_OnClick" />
                <MenuItem Header="미리보기 모드" Click="PreviewModeMenuItem_OnClick" />
                <Separator />
                <MenuItem x:Name="DefaultThemeMenuItem" Header="기본 테마" IsCheckable="True" Click="DefaultThemeMenuItem_OnClick" />
                <MenuItem x:Name="DarkThemeMenuItem" Header="다크 테마" IsCheckable="True" Click="DarkThemeMenuItem_OnClick" />
            </MenuItem>
            <MenuItem Header="스타일(_S)" ItemContainerStyle="{StaticResource DropDownMenuItemStyle}">
                <MenuItem Header="현재 스타일을 기본값으로 저장" Click="SaveDefaultStyleButton_OnClick" />
                <Separator />
                <MenuItem Header="표 삽입" Click="InsertTableMenuItem_OnClick" />
                <MenuItem Header="체크리스트 삽입" Click="InsertChecklistMenuItem_OnClick" />
                <MenuItem Header="코드블럭 삽입" Click="InsertCodeBlockMenuItem_OnClick" />
                <MenuItem Header="이미지 삽입" Click="InsertImageMenuItem_OnClick" />
                <MenuItem Header="링크 삽입" Click="InsertLinkMenuItem_OnClick" />
                <MenuItem Header="구분선 삽입" Click="InsertDividerMenuItem_OnClick" />
            </MenuItem>
            <MenuItem Header="네트워크(_N)" ItemContainerStyle="{StaticResource DropDownMenuItemStyle}">
                <MenuItem Header="목록 새로고침" Click="RefreshPeersButton_OnClick" />
                <MenuItem Header="현재 탭 전송" Click="SendButton_OnClick" />
                <Separator />
                <MenuItem x:Name="StartupMenuItem"
                          Header="윈도우 시작 시 자동 실행"
                          IsCheckable="True"
                          Checked="StartupMenuItem_OnChecked"
                          Unchecked="StartupMenuItem_OnUnchecked" />
            </MenuItem>
        </Menu>

        <Border x:Name="ToolbarHost" Grid.Row="1" Background="{StaticResource ChromeBrush}" Padding="4,4">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <Button Style="{StaticResource ToolbarButtonStyle}" Click="NewButton_OnClick" Content="새 탭" MinWidth="64" />
                    <Button Style="{StaticResource ToolbarButtonStyle}" Click="OpenButton_OnClick" Content="열기" />
                    <Button Style="{StaticResource ToolbarButtonStyle}" Click="SaveButton_OnClick" Content="저장" />
                    <Button Style="{StaticResource ToolbarButtonStyle}" Click="SaveAsButton_OnClick" Content="다른 저장" MinWidth="72" />
                    <Button Style="{StaticResource ToolbarButtonStyle}" Click="CloseTabButton_OnClick" Content="닫기" />
                    <Rectangle Width="1" Fill="#4A4A4A" Margin="4,2,8,2" />
                    <TextBlock VerticalAlignment="Center" Margin="0,0,4,0" Foreground="#CFCFCF" FontSize="12" Text="글꼴" />
                    <ComboBox x:Name="FontFamilyComboBox"
                              Width="150"
                              Height="24"
                              Margin="0,0,6,0"
                              FontSize="12"
                              SelectionChanged="FontFamilyComboBox_OnSelectionChanged" />
                    <TextBlock VerticalAlignment="Center" Margin="0,0,4,0" Foreground="#CFCFCF" FontSize="12" Text="크기" />
                    <ComboBox x:Name="FontSizeComboBox"
                              Width="54"
                              Height="24"
                              Margin="0,0,6,0"
                              FontSize="12"
                              SelectionChanged="FontSizeComboBox_OnSelectionChanged" />
                    <Button Style="{StaticResource ToolbarButtonStyle}" MinWidth="70" Click="SaveDefaultStyleButton_OnClick" Content="기본값" />
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Margin="0,0,8,0">
                        <RadioButton x:Name="EditModeButton" Style="{StaticResource ModeButtonStyle}" Checked="EditModeButton_OnChecked" Content="편집" />
                        <RadioButton x:Name="PreviewModeButton" Style="{StaticResource ModeButtonStyle}" Checked="PreviewModeButton_OnChecked" Content="미리보기" />
                    </StackPanel>
                    <ComboBox x:Name="PeerComboBox" Style="{StaticResource PeerComboStyle}" DisplayMemberPath="DisplayName" />
                    <Button Style="{StaticResource ToolbarButtonStyle}" Click="RefreshPeersButton_OnClick" Content="새로고침" MinWidth="64" />
                    <Button Style="{StaticResource ToolbarButtonStyle}" Click="SendButton_OnClick" Content="전송" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="2" Background="#172235" BorderBrush="#24324A" BorderThickness="0,1,0,0" Padding="14,8" Visibility="Collapsed">
            <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="#CBD5E1" FontWeight="SemiBold" Text="스타일" />
                <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="#94A3B8" Text="글꼴" />
                <ComboBox DockPanel.Dock="Left" Width="220" Height="32" Margin="0,0,10,0" />
                <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="#94A3B8" Text="크기" />
                <ComboBox DockPanel.Dock="Left" Width="78" Height="32" Margin="0,0,10,0" />
                <Button DockPanel.Dock="Left" Style="{StaticResource ToolbarButtonStyle}" MinWidth="96" Content="기본값 저장" />
                <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" Margin="4,0,0,0" Foreground="#94A3B8" Text="Ctrl+휠로 현재 탭 글자 크기 조절" />
            </DockPanel>
        </Border>

        <Border x:Name="SearchBar" Grid.Row="2" Background="#FFF7D6" BorderBrush="#E6C75A" BorderThickness="0,0,0,1" Padding="14,8" Visibility="Collapsed">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold" Foreground="#8A6400" Text="검색" />
                <Button DockPanel.Dock="Right" Style="{StaticResource SearchButtonStyle}" Width="34" Click="CloseSearchButton_OnClick" Content="×" />
                <Button DockPanel.Dock="Right" Style="{StaticResource SearchButtonStyle}" Click="FindNextButton_OnClick" Content="다음" />
                <Button DockPanel.Dock="Right" Style="{StaticResource SearchButtonStyle}" Click="FindPrevButton_OnClick" Content="이전" />
                <TextBlock x:Name="SearchStatusTextBlock" DockPanel.Dock="Right" Width="96" VerticalAlignment="Center" Foreground="#8A6400" TextAlignment="Center" />
                <TextBox x:Name="SearchTextBox" Style="{StaticResource ModernTextBoxStyle}" TextChanged="SearchTextBox_OnTextChanged" KeyDown="SearchTextBox_OnKeyDown" />
            </DockPanel>
        </Border>

        <Border x:Name="UnusedOldStyleBar" Grid.Row="2" Visibility="Collapsed">
            <DockPanel LastChildFill="False">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock />
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>
        <Border x:Name="TabBarHost" Grid.Row="3" Background="#252526" BorderBrush="#3E3E42" BorderThickness="0,1,0,1" Padding="0,2,12,0">
            <ListBox x:Name="TabsListBox"
                     ItemsSource="{Binding Tabs}"
                     SelectionChanged="TabsListBox_OnSelectionChanged"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     ScrollViewer.VerticalScrollBarVisibility="Disabled"
                     ItemContainerStyle="{StaticResource TabListBoxItemStyle}"
                     BorderThickness="0"
                     Background="Transparent">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Margin="0,0,14,0" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border x:Name="TabRoot" MinWidth="145" MaxWidth="250" Height="28" Margin="0,0,-1,0" Padding="10,0,6,0" Background="#2D2D2D" BorderBrush="#555555" BorderThickness="0,0,1,0" CornerRadius="0">
                            <DockPanel>
                                <Button DockPanel.Dock="Right"
                                        Width="18"
                                        Height="18"
                                        Margin="8,0,0,0"
                                        Padding="0"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Foreground="#CCCCCC"
                                        FontSize="12"
                                        Click="TabCloseButton_OnClick"
                                        Content="×" />
                                <TextBlock VerticalAlignment="Center"
                                           Foreground="#DCDCDC"
                                           FontSize="12"
                                           Text="{Binding DisplayTitle}"
                                           TextTrimming="CharacterEllipsis" />
                            </DockPanel>
                        </Border>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                <Setter TargetName="TabRoot" Property="Background" Value="#4D5D5D" />
                                <Setter TargetName="TabRoot" Property="BorderBrush" Value="#7D8D8D" />
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <Grid Grid.Row="4" Margin="0" PreviewMouseWheel="ContentHost_OnPreviewMouseWheel">
            <Border x:Name="EditorHost" Background="#3B3B3B" BorderBrush="#1E1E1E" BorderThickness="0" CornerRadius="0" Padding="0">
                <TextBox x:Name="EditorTextBox"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         Background="#3B3B3B"
                         BorderThickness="0"
                         FontFamily="Consolas"
                         FontSize="15"
                         Foreground="#F0F0F0"
                         CaretBrush="#FFFFFF"
                         HorizontalScrollBarVisibility="Auto"
                         VerticalScrollBarVisibility="Auto"
                         TextChanged="EditorTextBox_OnTextChanged"
                         PreviewKeyDown="EditorTextBox_OnPreviewKeyDown"
                         Padding="18,12"
                         TextWrapping="NoWrap" />
            </Border>
            <Border x:Name="PreviewHost" Background="#FAFAFA" BorderBrush="#1E1E1E" BorderThickness="0" CornerRadius="0" Padding="0" Visibility="Collapsed">
                <wv2:WebView2 x:Name="PreviewWebView" DefaultBackgroundColor="#FFFAFAFA" NavigationCompleted="PreviewWebView_OnNavigationCompleted" />
            </Border>
        </Grid>

        <Border x:Name="StatusHost" Grid.Row="5" Background="{StaticResource ChromeBrush}" Padding="4,0">
            <DockPanel>
                <TextBlock x:Name="LanStatusTextBlock" DockPanel.Dock="Right" Foreground="#BFBFBF" VerticalAlignment="Center" />
                <TextBlock x:Name="StatusTextBlock" Foreground="#DCDCDC" VerticalAlignment="Center" Text="Ready" />
            </DockPanel>
        </Border>
    </Grid>
</Window>

<Window x:Class="MdPad.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="MD Pad" Width="1180" Height="780" MinWidth="760" MinHeight="520"
        Icon="/Assets/App.ico"
        Background="#F5F5F5"
        AllowDrop="True"
        DragOver="Window_OnDragOver"
        Drop="Window_OnDrop"
        Closing="Window_OnClosing">
    <Window.Resources>
        <SolidColorBrush x:Key="ChromeBrush" Color="#F3F3F3" />
        <SolidColorBrush x:Key="ChromeElevatedBrush" Color="#E8E8E8" />
        <SolidColorBrush x:Key="AccentBrush" Color="#D7A21C" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FAFAFA" />
        <SolidColorBrush x:Key="SurfaceMutedBrush" Color="#E6E1D8" />
        <SolidColorBrush x:Key="LineBrush" Color="#B8B8B8" />
        <SolidColorBrush x:Key="TextBrush" Color="#111827" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#5F6368" />
        <SolidColorBrush x:Key="MenuForegroundBrush" Color="#111827" />
        <SolidColorBrush x:Key="ToolbarButtonBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="ToolbarButtonHoverBrush" Color="#EDF5FF" />
        <SolidColorBrush x:Key="ToolbarButtonPressedBrush" Color="#DCEBFF" />
        <SolidColorBrush x:Key="ToolbarButtonBorderBrush" Color="#C9D1D9" />
        <SolidColorBrush x:Key="ToolbarButtonForegroundBrush" Color="#111827" />
        <SolidColorBrush x:Key="ToolbarLabelBrush" Color="#404040" />
        <SolidColorBrush x:Key="TabItemBackgroundBrush" Color="#ECECEC" />
        <SolidColorBrush x:Key="TabItemForegroundBrush" Color="#111827" />
        <SolidColorBrush x:Key="TabItemSelectedBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="TabItemSelectedForegroundBrush" Color="#111827" />
        <SolidColorBrush x:Key="TabItemBorderBrush" Color="#B8B8B8" />

        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="28" />
            <Setter Property="MinWidth" Value="58" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="Padding" Value="9,0" />
            <Setter Property="Background" Value="{DynamicResource ToolbarButtonBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ToolbarButtonBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource ToolbarButtonForegroundBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="ToolTipService.ShowDuration" Value="12000" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource ToolbarButtonHoverBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource ToolbarButtonBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource ToolbarButtonPressedBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolbarIconTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe Fluent Icons" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="Background" Value="#F2C94C" />
            <Setter Property="BorderBrush" Value="#D6A719" />
            <Setter Property="Foreground" Value="#1F1F1F" />
        </Style>

        <Style x:Key="LightButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="Background" Value="#FFFDF8" />
            <Setter Property="BorderBrush" Value="#D8C9A9" />
            <Setter Property="Foreground" Value="#172033" />
        </Style>

        <Style x:Key="SearchButtonStyle" TargetType="Button" BasedOn="{StaticResource LightButtonStyle}">
            <Setter Property="Height" Value="30" />
            <Setter Property="MinWidth" Value="54" />
            <Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="Padding" Value="10,0" />
        </Style>

        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#FFFDF8" />
            <Setter Property="BorderBrush" Value="#D8C9A9" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#172033" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#F6ECD4" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#EBDDBF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModeButtonStyle" TargetType="RadioButton">
            <Setter Property="Height" Value="28" />
            <Setter Property="MinWidth" Value="74" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="Foreground" Value="{DynamicResource ToolbarButtonForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ToolbarButtonBorderBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root" Background="Transparent" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource ToolbarButtonHoverBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource ToolbarButtonForegroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#4D5D5D" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#6F8585" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="#FFFDF8" />
            <Setter Property="BorderBrush" Value="#D8C9A9" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#172033" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#D6A719" />
                                <Setter TargetName="Root" Property="BorderThickness" Value="2" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolbarComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="24" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="#111827" />
            <Setter Property="BorderBrush" Value="#A8A8A8" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="TabListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Panel.ZIndex" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Panel.ZIndex" Value="10" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Panel.ZIndex" Value="9" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TabScrollButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource TabItemForegroundBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#3E3E42" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TopMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Foreground" Value="{DynamicResource MenuForegroundBrush}" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="DropDownMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Foreground" Value="#111111" />
            <Setter Property="Background" Value="#F0F0F0" />
            <Setter Property="FontSize" Value="12" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="32" />
            <RowDefinition Height="*" />
            <RowDefinition Height="30" />
        </Grid.RowDefinitions>

        <Menu x:Name="MainMenu" Grid.Row="0" Background="{StaticResource ChromeBrush}" Foreground="{DynamicResource MenuForegroundBrush}" FontSize="12" Padding="2,0" ItemContainerStyle="{StaticResource TopMenuItemStyle}">
            <MenuItem Header="파일(_F)" ItemContainerStyle="{StaticResource DropDownMenuItemStyle}">
                <MenuItem x:Name="NewTabMenuItem" Header="새 탭" InputGestureText="Ctrl+T" Click="NewButton_OnClick" />
                <MenuItem Header="열기..." InputGestureText="Ctrl+O" Click="OpenButton_OnClick" />
                <MenuItem x:Name="RecentDocumentsMenuItem" Header="최근 열었던 문서" />
                <MenuItem x:Name="TrashDocumentsMenuItem" Header="휴지통" />
                <Separator />
                <MenuItem Header="저장" InputGestureText="Ctrl+S" Click="SaveButton_OnClick" />
                <MenuItem Header="다른 이름으로 저장..." Click="SaveAsButton_OnClick" />
                <Separator />
                <MenuItem x:Name="CloseTabMenuItem" Header="탭 닫기" InputGestureText="Ctrl+W" Click="CloseTabButton_OnClick" />
            </MenuItem>
            <MenuItem Header="편집(_E)" ItemContainerStyle="{StaticResource DropDownMenuItemStyle}">
                <MenuItem Header="찾기" InputGestureText="Ctrl+F" Click="ShowSearchMenuItem_OnClick" />
                <MenuItem Header="글자 크게" InputGestureText="Ctrl+Wheel Up" Click="IncreaseFontMenuItem_OnClick" />
                <MenuItem Header="글자 작게" InputGestureText="Ctrl+Wheel Down" Click="DecreaseFontMenuItem_OnClick" />
            </MenuItem>
            <MenuItem Header="보기(_V)" ItemContainerStyle="{StaticResource DropDownMenuItemStyle}">
                <MenuItem Header="편집 모드" Click="EditModeMenuItem_OnClick" />
                <MenuItem Header="미리보기 모드" Click="PreviewModeMenuItem_OnClick" />
                <MenuItem Header="분할 모드" Click="SplitModeMenuItem_OnClick" />
                <Separator />
                <MenuItem x:Name="DefaultThemeMenuItem" Header="기본 테마" IsCheckable="True" Click="DefaultThemeMenuItem_OnClick" />
                <MenuItem x:Name="DarkThemeMenuItem" Header="다크 테마" IsCheckable="True" Click="DarkThemeMenuItem_OnClick" />
            </MenuItem>
            <MenuItem Header="스타일(_S)" ItemContainerStyle="{StaticResource DropDownMenuItemStyle}">
                <MenuItem Header="글꼴..." Click="FontStyleMenuItem_OnClick" />
                <Separator />
                <MenuItem x:Name="TableInsertMenuItem" Header="표 삽입" Click="InsertTableMenuItem_OnClick" />
                <MenuItem x:Name="ChecklistInsertMenuItem" Header="체크리스트 삽입" Click="InsertChecklistMenuItem_OnClick" />
                <MenuItem x:Name="CodeBlockInsertMenuItem" Header="코드블럭 삽입" Click="InsertCodeBlockMenuItem_OnClick" />
                <MenuItem x:Name="ImageInsertMenuItem" Header="이미지 삽입" Click="InsertImageMenuItem_OnClick" />
                <MenuItem x:Name="LinkInsertMenuItem" Header="링크 삽입" Click="InsertLinkMenuItem_OnClick" />
                <MenuItem x:Name="DividerInsertMenuItem" Header="구분선 삽입" Click="InsertDividerMenuItem_OnClick" />
                <Separator />
                <MenuItem Header="예제 삽입">
                    <MenuItem Header="제목 / 문단" Tag="heading" Click="InsertMarkdownExampleMenuItem_OnClick" />
                    <MenuItem Header="목록" Tag="list" Click="InsertMarkdownExampleMenuItem_OnClick" />
                    <MenuItem Header="체크리스트" Tag="checklist" Click="InsertMarkdownExampleMenuItem_OnClick" />
                    <MenuItem Header="표" Tag="table" Click="InsertMarkdownExampleMenuItem_OnClick" />
                    <MenuItem Header="코드블럭" Tag="code" Click="InsertMarkdownExampleMenuItem_OnClick" />
                    <MenuItem Header="인용 / 구분선" Tag="quote" Click="InsertMarkdownExampleMenuItem_OnClick" />
                    <MenuItem Header="링크 / 이미지 URL" Tag="link-image" Click="InsertMarkdownExampleMenuItem_OnClick" />
                    <MenuItem Header="로컬 이미지 sample.png" Tag="local-image" Click="InsertMarkdownExampleMenuItem_OnClick" />
                    <MenuItem Header="이미지 크기 지정 HTML" Tag="image-size" Click="InsertMarkdownExampleMenuItem_OnClick" />
                </MenuItem>
            </MenuItem>
            <MenuItem Header="옵션(_O)" ItemContainerStyle="{StaticResource DropDownMenuItemStyle}">
                <MenuItem x:Name="StartupMenuItem"
                          Header="윈도우 시작 시 자동 실행"
                          IsCheckable="True"
                          Checked="StartupMenuItem_OnChecked"
                          Unchecked="StartupMenuItem_OnUnchecked" />
                <Separator />
                <MenuItem Header="스타일 단축키">
                    <MenuItem x:Name="TableShortcutMenuItem" Header="표 삽입..." Click="TableShortcutMenuItem_OnClick" />
                    <MenuItem x:Name="ChecklistShortcutMenuItem" Header="체크리스트 삽입..." Click="ChecklistShortcutMenuItem_OnClick" />
                    <MenuItem x:Name="CodeBlockShortcutMenuItem" Header="코드블럭 삽입..." Click="CodeBlockShortcutMenuItem_OnClick" />
                    <MenuItem x:Name="ImageShortcutMenuItem" Header="이미지 삽입..." Click="ImageShortcutMenuItem_OnClick" />
                    <MenuItem x:Name="LinkShortcutMenuItem" Header="링크 삽입..." Click="LinkShortcutMenuItem_OnClick" />
                    <MenuItem x:Name="DividerShortcutMenuItem" Header="구분선 삽입..." Click="DividerShortcutMenuItem_OnClick" />
                </MenuItem>
                <MenuItem Header="앱 단축키">
                    <MenuItem x:Name="NewTabShortcutMenuItem" Header="새 탭..." Click="NewTabShortcutMenuItem_OnClick" />
                    <MenuItem x:Name="NextTabShortcutMenuItem" Header="다음 탭..." Click="NextTabShortcutMenuItem_OnClick" />
                    <MenuItem x:Name="PreviousTabShortcutMenuItem" Header="이전 탭..." Click="PreviousTabShortcutMenuItem_OnClick" />
                    <MenuItem x:Name="CloseTabShortcutMenuItem" Header="탭 닫기..." Click="CloseTabShortcutMenuItem_OnClick" />
                </MenuItem>
                <MenuItem Header="단축키 기본값으로 초기화" Click="ResetShortcutsMenuItem_OnClick" />
                <Separator />
                <MenuItem Header="오픈소스 라이선스" Click="OpenSourceLicensesMenuItem_OnClick" />
                <Separator />
                <MenuItem Header="버전 정보" Click="VersionInfoMenuItem_OnClick" />
            </MenuItem>
        </Menu>

        <Border x:Name="ToolbarHost" Grid.Row="1" Background="{StaticResource ChromeBrush}" Padding="4,4">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <Button Style="{StaticResource ToolbarButtonStyle}" Click="NewButton_OnClick" MinWidth="70" ToolTip="새 탭">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource ToolbarIconTextStyle}" Text="&#xE710;" />
                            <TextBlock VerticalAlignment="Center" Text="새 탭" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ToolbarButtonStyle}" Click="OpenButton_OnClick" ToolTip="파일 열기">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource ToolbarIconTextStyle}" Text="&#xE8E5;" />
                            <TextBlock VerticalAlignment="Center" Text="열기" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ToolbarButtonStyle}" Click="SaveButton_OnClick" ToolTip="저장">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource ToolbarIconTextStyle}" Text="&#xE74E;" />
                            <TextBlock VerticalAlignment="Center" Text="저장" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ToolbarButtonStyle}" Click="SaveAsButton_OnClick" MinWidth="86" ToolTip="다른 이름으로 저장">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource ToolbarIconTextStyle}" Text="&#xE792;" />
                            <TextBlock VerticalAlignment="Center" Text="다른 저장" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ToolbarButtonStyle}" Click="CloseTabButton_OnClick" ToolTip="탭 닫기">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource ToolbarIconTextStyle}" Text="&#xE711;" />
                            <TextBlock VerticalAlignment="Center" Text="닫기" />
                        </StackPanel>
                    </Button>
                    <Rectangle Width="1" Fill="#4A4A4A" Margin="4,2,8,2" />
                    <Button Style="{StaticResource ToolbarButtonStyle}" Click="InsertTableMenuItem_OnClick" ToolTip="표 삽입">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource ToolbarIconTextStyle}" Text="&#xE80A;" />
                            <TextBlock VerticalAlignment="Center" Text="표" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ToolbarButtonStyle}" Click="InsertChecklistMenuItem_OnClick" ToolTip="체크리스트 삽입">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource ToolbarIconTextStyle}" Text="&#xE73E;" />
                            <TextBlock VerticalAlignment="Center" Text="체크" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ToolbarButtonStyle}" Click="InsertCodeBlockMenuItem_OnClick" ToolTip="코드블럭 삽입">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource ToolbarIconTextStyle}" Text="&#xE943;" />
                            <TextBlock VerticalAlignment="Center" Text="코드" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ToolbarButtonStyle}" Click="InsertImageMenuItem_OnClick" ToolTip="이미지 삽입">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource ToolbarIconTextStyle}" Text="&#xEB9F;" />
                            <TextBlock VerticalAlignment="Center" Text="이미지" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ToolbarButtonStyle}" Click="InsertLinkMenuItem_OnClick" ToolTip="링크 삽입">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource ToolbarIconTextStyle}" Text="&#xE71B;" />
                            <TextBlock VerticalAlignment="Center" Text="링크" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ToolbarButtonStyle}" Click="InsertDividerMenuItem_OnClick" ToolTip="구분선 삽입">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource ToolbarIconTextStyle}" Text="&#xE949;" />
                            <TextBlock VerticalAlignment="Center" Text="구분선" />
                        </StackPanel>
                    </Button>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource ToolbarButtonStyle}" MinWidth="92" Click="CollapseAllCodeButton_OnClick" ToolTip="코드블럭 모두 접기">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource ToolbarIconTextStyle}" Text="&#xE70D;" />
                            <TextBlock VerticalAlignment="Center" Text="코드 접기" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ToolbarButtonStyle}" MinWidth="92" Click="ExpandAllCodeButton_OnClick" ToolTip="코드블럭 모두 펼치기">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource ToolbarIconTextStyle}" Text="&#xE70E;" />
                            <TextBlock VerticalAlignment="Center" Text="코드 펼치기" />
                        </StackPanel>
                    </Button>
                    <StackPanel Orientation="Horizontal" Margin="0,0,8,0">
                        <RadioButton x:Name="EditModeButton" Style="{StaticResource ModeButtonStyle}" Checked="EditModeButton_OnChecked" Content="편집" />
                        <RadioButton x:Name="PreviewModeButton" Style="{StaticResource ModeButtonStyle}" Checked="PreviewModeButton_OnChecked" Content="미리보기" />
                        <RadioButton x:Name="SplitModeButton" Style="{StaticResource ModeButtonStyle}" Checked="SplitModeButton_OnChecked" Content="분할" />
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="2" Background="#172235" BorderBrush="#24324A" BorderThickness="0,1,0,0" Padding="14,8" Visibility="Collapsed">
            <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="#CBD5E1" FontWeight="SemiBold" Text="스타일" />
                <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="#94A3B8" Text="글꼴" />
                <ComboBox x:Name="FontFamilyComboBox" DockPanel.Dock="Left" Width="220" Height="32" Margin="0,0,10,0" SelectionChanged="FontFamilyComboBox_OnSelectionChanged" />
                <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="#94A3B8" Text="크기" />
                <ComboBox x:Name="FontSizeComboBox" DockPanel.Dock="Left" Width="78" Height="32" Margin="0,0,10,0" SelectionChanged="FontSizeComboBox_OnSelectionChanged" />
                <Button DockPanel.Dock="Left" Style="{StaticResource ToolbarButtonStyle}" MinWidth="96" Click="SaveDefaultStyleButton_OnClick" Content="기본값 저장" />
                <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" Margin="4,0,0,0" Foreground="#94A3B8" Text="Ctrl+휠로 현재 탭 글자 크기 조절" />
            </DockPanel>
        </Border>

        <Border x:Name="SearchBar" Grid.Row="2" Background="#F1F5F9" BorderBrush="#CBD5E1" BorderThickness="0,0,0,1" Padding="10,7,10,9" Visibility="Collapsed"
                ToolTip="Esc 1회: 검색어 초기화 / 검색어가 빈 상태에서 Esc: 닫기">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0">
                    <TextBlock x:Name="SearchLabelTextBlock" DockPanel.Dock="Left" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold" Foreground="#334155" Text="검색" />
                    <Button x:Name="CloseSearchButton" DockPanel.Dock="Right" Style="{StaticResource SearchButtonStyle}" Click="CloseSearchButton_OnClick" Content="닫기" />
                    <Button x:Name="ResetSearchButton" DockPanel.Dock="Right" Style="{StaticResource SearchButtonStyle}" Click="ResetSearchButton_OnClick" Content="초기화" />
                    <Button DockPanel.Dock="Right" Style="{StaticResource SearchButtonStyle}" Click="FindNextButton_OnClick" Content="다음" />
                    <Button DockPanel.Dock="Right" Style="{StaticResource SearchButtonStyle}" Click="FindPrevButton_OnClick" Content="이전" />
                    <TextBlock x:Name="SearchStatusTextBlock" DockPanel.Dock="Right" Width="96" VerticalAlignment="Center" Foreground="#8A6400" TextAlignment="Center" />
                    <TextBox x:Name="SearchTextBox" Style="{StaticResource ModernTextBoxStyle}" TextChanged="SearchTextBox_OnTextChanged" KeyDown="SearchTextBox_OnKeyDown" />
                </DockPanel>
                <TextBlock x:Name="SearchHintTextBlock" Grid.Row="1" Margin="34,5,0,0" FontSize="11" Foreground="#64748B"
                           Text="Esc: 검색어 초기화, 빈 상태에서 Esc: 닫기" />
            </Grid>
        </Border>

        <Border x:Name="ReplaceBar" Grid.Row="2" Background="#F1F5F9" BorderBrush="#CBD5E1" BorderThickness="0,0,0,1" Padding="10,7" Visibility="Collapsed">
            <DockPanel>
                <Button DockPanel.Dock="Right" Style="{StaticResource SearchButtonStyle}" Click="CloseReplaceButton_OnClick" Content="닫기" />
                <Button DockPanel.Dock="Right" Style="{StaticResource SearchButtonStyle}" Click="ReplaceAllButton_OnClick" Content="모두 바꾸기" />
                <Button DockPanel.Dock="Right" Style="{StaticResource SearchButtonStyle}" Click="ReplaceOneButton_OnClick" Content="바꾸기" />
                <Button DockPanel.Dock="Right" Style="{StaticResource SearchButtonStyle}" Click="FindNextButton_OnClick" Content="다음 찾기" />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,10,0">
                    <RadioButton x:Name="ReplaceCurrentTabRadio" Foreground="{DynamicResource ToolbarButtonForegroundBrush}" Margin="0,0,8,0" IsChecked="True" Content="현재 탭" />
                    <RadioButton x:Name="ReplaceAllTabsRadio" Foreground="{DynamicResource ToolbarButtonForegroundBrush}" Margin="0,0,8,0" Content="모든 탭" />
                    <RadioButton x:Name="ReplaceSelectionRadio" Foreground="{DynamicResource ToolbarButtonForegroundBrush}" Content="선택 영역 우선" />
                </StackPanel>
                <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold" Foreground="{DynamicResource ToolbarButtonForegroundBrush}" Text="찾기" />
                <TextBox x:Name="ReplaceFindTextBox" DockPanel.Dock="Left" Width="220" Style="{StaticResource ModernTextBoxStyle}" TextChanged="ReplaceFindTextBox_OnTextChanged" KeyDown="ReplaceTextBox_OnKeyDown" />
                <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" Margin="10,0,8,0" FontWeight="SemiBold" Foreground="{DynamicResource ToolbarButtonForegroundBrush}" Text="바꾸기" />
                <TextBox x:Name="ReplaceTextBox" Style="{StaticResource ModernTextBoxStyle}" KeyDown="ReplaceTextBox_OnKeyDown" />
            </DockPanel>
        </Border>

        <Border x:Name="UnusedOldStyleBar" Grid.Row="2" Visibility="Collapsed">
            <DockPanel LastChildFill="False">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock />
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>
        <Border x:Name="TabBarHost" Grid.Row="3" Background="#252526" BorderBrush="#3E3E42" BorderThickness="0,1,0,1" Padding="6,3,6,0">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="2,0,4,0">
                    <Button x:Name="TabScrollLeftButton" Style="{StaticResource TabScrollButtonStyle}" Click="TabScrollLeftButton_OnClick" Content="‹" />
                    <Button x:Name="TabScrollRightButton" Style="{StaticResource TabScrollButtonStyle}" Click="TabScrollRightButton_OnClick" Content="›" />
                </StackPanel>
                <ListBox x:Name="TabsListBox"
                         ItemsSource="{Binding Tabs}"
                         SelectionChanged="TabsListBox_OnSelectionChanged"
                         PreviewMouseWheel="TabsListBox_OnPreviewMouseWheel"
                         PreviewMouseLeftButtonDown="TabsListBox_OnPreviewMouseLeftButtonDown"
                         PreviewMouseMove="TabsListBox_OnPreviewMouseMove"
                         PreviewMouseLeftButtonUp="TabsListBox_OnPreviewMouseLeftButtonUp"
                         LostMouseCapture="TabsListBox_OnLostMouseCapture"
                         Loaded="TabsListBox_OnLoaded"
                         ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled"
                         ItemContainerStyle="{StaticResource TabListBoxItemStyle}"
                         BorderThickness="0"
                         Background="Transparent">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,0,14,0" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="TabRoot" MinWidth="145" MaxWidth="250" Height="29" Margin="0,0,-12,0" Padding="10,0,18,0" Background="{DynamicResource TabItemBackgroundBrush}" BorderBrush="{DynamicResource TabItemBorderBrush}" BorderThickness="1,1,1,0" CornerRadius="6,6,0,0" MouseLeftButtonDown="TabRoot_OnMouseLeftButtonDown">
                                <Border.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="탐색기에서 열기" Click="TabContextOpenInExplorerMenuItem_OnClick" />
                                        <MenuItem Header="현재 경로주소 복사" Click="TabContextCopyPathMenuItem_OnClick" />
                                        <Separator />
                                        <MenuItem Header="탭 닫기" Click="TabContextCloseMenuItem_OnClick" />
                                        <MenuItem Header="이 탭 기준 오른쪽 닫기" Click="TabContextCloseRightMenuItem_OnClick" />
                                        <MenuItem Header="전체 닫기" Click="TabContextCloseAllMenuItem_OnClick" />
                                    </ContextMenu>
                                </Border.ContextMenu>
                                <DockPanel>
                                    <Button DockPanel.Dock="Right"
                                            Width="18"
                                            Height="18"
                                            Margin="8,0,0,0"
                                            Padding="0"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Foreground="{DynamicResource TabItemForegroundBrush}"
                                            FontSize="12"
                                            Click="TabCloseButton_OnClick"
                                            Content="×" />
                                    <TextBlock VerticalAlignment="Center"
                                               Foreground="{DynamicResource TabItemForegroundBrush}"
                                               FontSize="12"
                                               Text="{Binding DisplayTitle}"
                                               TextTrimming="CharacterEllipsis" />
                                </DockPanel>
                            </Border>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                    <Setter TargetName="TabRoot" Property="Background" Value="{DynamicResource TabItemSelectedBackgroundBrush}" />
                                    <Setter TargetName="TabRoot" Property="BorderBrush" Value="{DynamicResource TabItemBorderBrush}" />
                                    <Setter TargetName="TabRoot" Property="Height" Value="30" />
                                    <Setter TargetName="TabRoot" Property="Margin" Value="0,0,-8,0" />
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Grid x:Name="ContentGrid" Grid.Row="4" Margin="0" PreviewMouseWheel="ContentHost_OnPreviewMouseWheel" AllowDrop="True" PreviewDragOver="ContentHost_OnPreviewDragOver" PreviewDrop="ContentHost_OnPreviewDrop">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="EditorColumn" Width="*" />
                <ColumnDefinition x:Name="SplitSeparatorColumn" Width="0" />
                <ColumnDefinition x:Name="PreviewColumn" Width="0" />
            </Grid.ColumnDefinitions>
            <Border x:Name="EditorHost" Grid.Column="0" Background="#3B3B3B" BorderBrush="#1E1E1E" BorderThickness="0" CornerRadius="0" Padding="0">
                <TextBox x:Name="EditorTextBox"
                         AllowDrop="True"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         Background="#3B3B3B"
                         BorderThickness="0"
                         FontFamily="Consolas"
                         FontSize="15"
                         Foreground="#F0F0F0"
                         CaretBrush="#FFFFFF"
                         HorizontalScrollBarVisibility="Auto"
                         VerticalScrollBarVisibility="Auto"
                         TextChanged="EditorTextBox_OnTextChanged"
                         PreviewDragOver="ContentHost_OnPreviewDragOver"
                         PreviewDrop="ContentHost_OnPreviewDrop"
                         PreviewKeyDown="EditorTextBox_OnPreviewKeyDown"
                         Padding="18,12"
                         TextWrapping="NoWrap" />
            </Border>
            <GridSplitter x:Name="SplitGridSplitter" Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#3E3E42" Visibility="Collapsed" />
            <Border x:Name="PreviewHost" Grid.Column="2" Background="#FAFAFA" BorderBrush="#1E1E1E" BorderThickness="0" CornerRadius="0" Padding="0" Visibility="Collapsed" AllowDrop="True" PreviewDragOver="ContentHost_OnPreviewDragOver" PreviewDrop="ContentHost_OnPreviewDrop">
                <wv2:WebView2 x:Name="PreviewWebView" DefaultBackgroundColor="#FFFAFAFA" NavigationCompleted="PreviewWebView_OnNavigationCompleted" AllowDrop="False" />
            </Border>
        </Grid>

        <Border x:Name="StatusHost" Grid.Row="5" Background="{StaticResource ChromeBrush}" Padding="4,0">
            <DockPanel>
                <TextBlock x:Name="StatusTextBlock" Foreground="#DCDCDC" VerticalAlignment="Center" Text="Ready" />
            </DockPanel>
        </Border>

        <Border x:Name="TabSwitcherOverlay"
                Grid.Row="0"
                Grid.RowSpan="6"
                Width="620"
                MaxHeight="560"
                Padding="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#202020"
                BorderBrush="#8A8A8A"
                BorderThickness="1"
                Visibility="Collapsed">
            <Border.Effect>
                <DropShadowEffect BlurRadius="18" ShadowDepth="4" Opacity="0.35" />
            </Border.Effect>
            <DockPanel>
                <Border DockPanel.Dock="Top" Background="#2D2D30" Padding="10,7">
                    <TextBlock x:Name="TabSwitcherTitleTextBlock"
                               Foreground="#F3F4F6"
                               FontWeight="SemiBold"
                               Text="Ctrl을 떼면 선택한 탭으로 이동" />
                </Border>
                <ListBox x:Name="TabSwitcherListBox"
                         ItemsSource="{Binding Tabs}"
                         Background="#1E1E1E"
                         BorderThickness="0"
                         Foreground="#F3F4F6"
                         PreviewMouseLeftButtonUp="TabSwitcherListBox_OnPreviewMouseLeftButtonUp"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Foreground" Value="#E5E7EB" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Root" Background="{TemplateBinding Background}" Padding="10,6">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Root" Property="Background" Value="#3E5F7E" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <DockPanel LastChildFill="True">
                                <TextBlock DockPanel.Dock="Left"
                                           Width="18"
                                           Foreground="#7DD3FC"
                                           FontSize="14"
                                           Text="●" />
                                <StackPanel>
                                    <TextBlock Foreground="#F9FAFB"
                                               FontWeight="SemiBold"
                                               Text="{Binding DisplayTitle}"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Margin="0,2,0,0"
                                               Foreground="#CBD5E1"
                                               FontSize="12"
                                               Text="{Binding FilePath}"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </DockPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>
    </Grid>
</Window>
